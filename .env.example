# LibCounterAI local runtime configuration

# PostgreSQL + pgvector
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Optional full SQLAlchemy URL. If set, this takes precedence over POSTGRES_*.
# DATABASE_URL=postgresql://postgres:password@localhost:5432/libcounterai

# Redis
REDIS_HOST=localhost
REDIS_PORT=

# Privacy & retention
