UNKNOWN_EXPIRED_GRACE_HOURS=
RETENTION_CLEANUP_INTERVAL_SECONDS=
AUDIT_LOG_ENABLED=

# Local app ports
BACKEND_HOST=
BACKEND_PORT=
FRONTEND_HOST=
FRONTEND_PORT=

