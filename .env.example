# LibCounterAI local runtime configuration

# PostgreSQL + pgvector
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Optional full SQLAlchemy URL. If set, this takes precedence over POSTGRES_*.
# DATABASE_URL=postgresql://postgres:password@localhost:5432/libcounterai

# Redis
REDIS_HOST=localhost
REDIS_PORT=

# Auth & JWT
JWT_SECRET_KEY=
JWT_EXPIRE_MINUTES=

# File upload
MAX_UPLOAD_SIZE_MB=

# Privacy & retention
UNKNOWN_IDENTITY_EXPIRE_HOURS=
UNKNOWN_EXPIRED_GRACE_HOURS=
RETENTION_CLEANUP_INTERVAL_SECONDS=
AUDIT_LOG_ENABLED=

# CORS: comma-separated origins the frontend runs on (or "*" for dev)
CORS_ORIGINS=

# Local app ports
BACKEND_HOST=
BACKEND_PORT=
FRONTEND_HOST=
FRONTEND_PORT=

